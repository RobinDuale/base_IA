# .env.example -- variables nécessaires au serveur dynamique (server.js)
# Copier en .env.production.local sur le VPS -- ne jamais committer le vrai fichier.

# Port d'écoute interne du conteneur (Traefik route dessus)
PORT=3000

# Clé API Notion -- source unique de contenu, lue au démarrage et sur /internal/sync
NOTION_API_KEY=CHANGE_MOI

# Secret partagé avec n8n pour les endpoints POST /internal/sync et /internal/invalidate
# (les deux relisent Notion et reconstruisent le cache -- alias historiques, même comportement)
INVALIDATE_TOKEN=CHANGE_MOI
