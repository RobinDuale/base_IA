# .env.example -- variables nécessaires au serveur dynamique (server.js)
# Copier en .env.production.local sur le VPS -- ne jamais committer le vrai fichier.

# Connexion à la base Postgres dédiée base_ia (sur le même Postgres partagé du VPS)
DATABASE_URL=postgresql://base_ia_user:CHANGE_MOI@postgres:5432/base_ia

# Port d'écoute interne du conteneur (Traefik route dessus)
PORT=3000

# Clé API Notion -- utilisée uniquement par POST /internal/sync pour relire la base Outils
NOTION_API_KEY=CHANGE_MOI

# Secret partagé avec n8n pour les endpoints POST /internal/sync et /internal/invalidate
# /internal/sync   : relit Notion en entier, met à jour Postgres, reconstruit le cache (bouton "Mettre à jour", validation d'une proposition)
# /internal/invalidate : reconstruit juste le cache depuis Postgres tel quel, sans repasser par Notion
INVALIDATE_TOKEN=CHANGE_MOI
